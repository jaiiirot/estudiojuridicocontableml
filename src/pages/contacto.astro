---
// src/pages/contacto.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { siteInfo } from '../data/info';
---

<Layout title="Contacto">
  
  <header class="bg-gray-50 pt-32 pb-16 border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-dark mb-6">Contacto</h1>
      <p class="text-lg text-gray-600 font-light">
        Dejanos tu consulta y te contestaremos a la brevedad[cite: 127]. Estamos aquí para brindarte el respaldo legal y contable que necesitás.
      </p>
    </div>
  </header>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div class="space-y-10">
          <div>
            <h2 class="text-2xl font-serif font-bold text-brand-dark mb-6">Nuestras Oficinas</h2>
            <div class="space-y-6 text-gray-600 font-light text-lg">
              <div class="flex items-start">
                <span class="text-brand-primary mr-4 text-2xl">📍</span>
                <p>
                  <strong class="block text-gray-900 font-medium text-base mb-1">Dirección</strong>
                  Av. Pres. Bartolomé Mitre 2443,<br /> Avellaneda, Bs. As. [cite: 126]
                </p>
              </div>
              <div class="flex items-start">
                <span class="text-brand-primary mr-4 text-2xl">🕒</span>
                <p>
                  <strong class="block text-gray-900 font-medium text-base mb-1">Horario de Atención</strong>
                  Lunes a Viernes de 13 a 18hs[cite: 125].
                </p>
              </div>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-serif font-bold text-brand-dark mb-6">Comunicación Directa</h2>
            <ul class="space-y-4 text-gray-600 font-light text-lg">
              <li class="flex items-center">
                <span class="text-brand-primary mr-4 text-2xl">📞</span>
                <a href="tel:01177108303" class="hover:text-brand-primary transition-colors">Teléfono: 77108303 [cite: 116]</a>
              </li>
              <li class="flex items-center">
                <span class="text-brand-primary mr-4 text-2xl">📱</span>
                <a href={`https://wa.me/5491132989665`} class="hover:text-brand-primary transition-colors">WhatsApp: 1132989665 [cite: 117]</a>
              </li>
              <li class="flex items-center">
                <span class="text-brand-primary mr-4 text-2xl">✉️</span>
                <a href="mailto:info@estudiojuridicocontableml.com" class="hover:text-brand-primary transition-colors">info@estudiojuridicocontableml.com [cite: 126]</a>
              </li>
              <li class="flex items-center">
                <span class="text-brand-primary mr-4 text-2xl">📸</span>
                <a href="https://instagram.com/estudiojuridicocontableml" target="_blank" rel="noopener noreferrer" class="hover:text-brand-primary transition-colors">
                  Instagram: @estudiojuridicocontableml [cite: 124]
                </a>
              </li>
            </ul>
          </div>
        </div>

        <div class="bg-gray-50 p-8 md:p-10 rounded-2xl border border-gray-100 shadow-sm">
          <form id="contacto-form" class="space-y-6">
            
            <div>
              <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">Tu nombre (obligatorio) [cite: 128]</label>
              <input type="text" id="nombre" name="nombre" required 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-primary focus:border-brand-primary transition-colors outline-none bg-white" 
                placeholder="Ej. Juan Pérez">
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Tu correo electrónico (obligatorio) [cite: 129]</label>
              <input type="email" id="email" name="email" required 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-primary focus:border-brand-primary transition-colors outline-none bg-white" 
                placeholder="juan@ejemplo.com">
            </div>

            <div>
              <label for="asunto" class="block text-sm font-medium text-gray-700 mb-2">Asunto [cite: 130]</label>
              <input type="text" id="asunto" name="asunto" 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-primary focus:border-brand-primary transition-colors outline-none bg-white" 
                placeholder="Ej. Consulta por sucesión">
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-2">Tu mensaje [cite: 134]</label>
              <textarea id="mensaje" name="mensaje" rows="5" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-primary focus:border-brand-primary transition-colors outline-none text-gray-800 bg-white resize-none" 
                placeholder="Escribe tu consulta aquí..."></textarea>
            </div>

            <button type="submit" 
              class="w-full bg-brand-primary text-white font-medium py-4 rounded-lg hover:bg-brand-secondary transition-colors shadow-md mt-4">
              Enviar consulta [cite: 137]
            </button>
            
            <p id="form-status" class="text-sm text-center hidden mt-4"></p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Script de cliente (Vanilla JS) para manejar LocalStorage y validación
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contacto-form') as HTMLFormElement;
    if (!form) return;

    const inputs = form.querySelectorAll('input, textarea') as NodeListOf<HTMLInputElement | HTMLTextAreaElement>;
    const statusMsg = document.getElementById('form-status');

    // 1. Cargar datos del LocalStorage al inicializar
    inputs.forEach(input => {
      const savedValue = localStorage.getItem(`ml_draft_${input.name}`);
      if (savedValue) {
        input.value = savedValue;
      }

      // 2. Escuchar cambios y guardar en LocalStorage
      input.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement | HTMLTextAreaElement;
        localStorage.setItem(`ml_draft_${target.name}`, target.value);
      });
    });

    // 3. Manejar el envío
    form.addEventListener('submit', (e) => {
      e.preventDefault(); // Prevenir recarga para demostración (Aquí iría tu fetch a la API)
      
      // Simular envío exitoso
      if(statusMsg) {
        statusMsg.textContent = "¡Mensaje enviado con éxito! Te contactaremos pronto.";
        statusMsg.className = "text-sm text-center mt-4 text-green-600 font-medium block";
      }

      // Limpiar LocalStorage y formulario
      inputs.forEach(input => {
        localStorage.removeItem(`ml_draft_${input.name}`);
        input.value = '';
      });
      
      // Ocultar mensaje de éxito después de unos segundos
      setTimeout(() => {
        if(statusMsg) statusMsg.classList.add('hidden');
      }, 5000);
    });
  });
</script>