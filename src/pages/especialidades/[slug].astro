---
// src/pages/especialidades/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import SpecialtyHero from '../../components/especialidades/SpecialtyHero.astro';
import SpecialtyDetails from '../../components/especialidades/SpecialtyDetails.astro';
import { services } from '../../data/services';
import { siteInfo } from '../../data/info';

export function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const whatsappMensaje = encodeURIComponent(`Hola, quisiera recibir asesoramiento sobre ${service.title}.`);
---

<Layout 
  title={`${service.title} | Abogados y Contadores M&L`}
  description={service.shortDesc}
  image={service.image}
>
  
  <SpecialtyHero title={service.title} shortDesc={service.shortDesc} image={service.image} />

  <SpecialtyDetails 
    details={service.details} 
  />

  <section class="py-24 bg-brand-dark text-center border-t-4 border-brand-primary">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-6">¿Requiere intervención inmediata?</h2>
      <p class="text-gray-300 font-light text-lg mb-10 max-w-2xl mx-auto">
        Nuestro equipo de especialistas analizará su caso con absoluta confidencialidad para proponerle la mejor estrategia procesal o administrativa.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href={`https://wa.me/${siteInfo.contact.whatsapp}?text=${whatsappMensaje}`} 
           target="_blank" 
           class="inline-block bg-white text-brand-dark px-10 py-4 font-bold uppercase tracking-widest text-sm hover:bg-brand-primary hover:text-white transition-colors rounded-sm shadow-xl">
          Contactar por WhatsApp
        </a>
        <a href="/consulta" 
           class="inline-block bg-transparent border border-gray-500 text-white px-10 py-4 font-bold uppercase tracking-widest text-sm hover:border-white hover:bg-white/5 transition-colors rounded-sm">
          Consulta Preliminar (IA)
        </a>
      </div>
    </div>
  </section>

</Layout>