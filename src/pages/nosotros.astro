---
// src/pages/nosotros.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { siteInfo } from '../data/info';
---

<Layout title="Nosotros">
  
  <header class="bg-gray-50 pt-24 pb-16 border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-dark mb-6">Nosotros</h1>
      <p class="text-lg text-gray-600 font-light">
        Conocé quiénes somos y cómo podemos ayudarte a resolver tus conflictos.
      </p>
    </div>
  </header>

  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      
      <div class="text-center">
        <h2 class="text-3xl font-serif font-bold text-brand-dark mb-6">Nuestra Ubicación y Enfoque</h2>
        <p class="text-xl text-gray-700 font-light leading-relaxed">
          Somos un estudio jurídico contable ubicado en Avellaneda a 10 minutos de C.A.B.A.
        </p>
      </div>

      <hr class="border-gray-100" />

      <div class="bg-gray-50 p-10 rounded-2xl border-l-4 border-brand-primary">
        <h3 class="text-2xl font-serif font-bold text-brand-dark mb-4">Nuestro Objetivo</h3>
        <p class="text-lg text-gray-600 leading-relaxed">
          Nuestro objetivo es asesorar y brindarle a nuestros clientes una solución a sus necesidades y problemas jurídicos, legales, contables y económicos para particulares, PyMES y empresas. 
        </p>
      </div>

      <div class="bg-brand-dark text-white p-10 rounded-2xl shadow-lg relative overflow-hidden">
        <div class="relative z-10">
          <h3 class="text-2xl font-serif font-bold mb-4 text-brand-primary">Nuestro Diferencial</h3>
          <p class="text-lg text-gray-200 font-light leading-relaxed italic">
            "Nuestro diferencial es la calidez con la que recibimos a cada cliente, manteniendo un rol activo, asegurándonos de que comprendan cada alternativa y acompañándolos en la decisión final."
          </p>
        </div>
        <div class="absolute -bottom-10 -right-10 text-9xl opacity-5">⚖️</div>
      </div>

    </div>
    <div class="space-y-10">
  <div>
    <h2 class="text-2xl font-serif font-bold text-brand-dark mb-6">Nuestras Oficinas</h2>
    <div class="space-y-6 text-gray-700 font-light text-lg">
      <div class="flex items-start">
        <p>
          <strong class="block text-gray-900 font-medium text-base mb-1">Dirección</strong>
          Av. Pres. Bartolomé Mitre 2443,<br /> Avellaneda, Prov. de Buenos Aires.
        </p>
      </div>
      
      <div class="w-full h-64 rounded-xl overflow-hidden border border-gray-200 shadow-sm mt-6">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3281.332616238382!2d-58.349187!3d-34.671542!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95a33306bfb8e053%3A0x6e9f28d8b67f1b!2sAv.%20Pres.%20Bartolom%C3%A9%20Mitre%202443%2C%20Avellaneda%2C%20Provincia%20de%20Buenos%20Aires!5e0!3m2!1ses!2sar!4v1700000000000!5m2!1ses!2sar" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>
  </div>
  </div>
  </section>
  
</Layout>