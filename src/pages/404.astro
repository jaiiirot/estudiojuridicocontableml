---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página no encontrada">
  <section class="min-h-[70vh] flex items-center justify-center bg-gray-50 px-4">
    <div class="text-center max-w-2xl mx-auto">
      <span class="text-brand-primary text-6xl font-bold block mb-6">404</span>
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-brand-dark mb-4">
        No se encontró
      </h1>
      <p class="text-xl text-gray-600 font-light mb-10">
        Lo sentimos, pero estás buscando algo que no está aquí. 
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/" class="bg-brand-primary text-white px-8 py-3 rounded-full font-medium hover:bg-brand-secondary transition-colors">
          Volver al Inicio
        </a>
        <a href="/contacto" class="bg-white text-brand-dark border border-gray-300 px-8 py-3 rounded-full font-medium hover:border-brand-primary hover:text-brand-primary transition-colors">
          Contactarnos
        </a>
      </div>
    </div>
  </section>

</Layout>