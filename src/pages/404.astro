---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada">
  <section class="min-h-[70vh] flex items-center justify-center bg-web-background px-4 border-b border-web-secondary/50">
    <div class="text-center max-w-2xl mx-auto">
      <span class="text-web-primary text-6xl font-bold block mb-6 drop-shadow-md">404</span>
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
        No se encontró
      </h1>
      <p class="text-xl text-web-text/80 font-light mb-10">
        Lo sentimos, pero estás buscando algo que no está aquí.
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/" class="bg-web-accent text-white px-8 py-3 rounded-full font-medium hover:bg-web-secondary transition-colors shadow-lg">
          Volver al Inicio
        </a>
        <a href="/contacto" class="bg-web-secondary/50 text-white border border-web-secondary px-8 py-3 rounded-full font-medium hover:border-web-primary hover:bg-web-secondary transition-colors">
          Contactarnos
        </a>
      </div>
  
    </div>
  </section>
</Layout>