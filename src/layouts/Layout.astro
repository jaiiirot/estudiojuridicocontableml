---
// src/layouts/Layout.astro
// CAMBIA ESTO: import { ViewTransitions } from 'astro:transitions';
import { ClientRouter } from 'astro:transitions'; // <- NUEVO IMPORT
import { siteInfo } from '../data/info';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={siteInfo.description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | {siteInfo.name}</title>
    <ClientRouter /> </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased selection:bg-brand-primary selection:text-white">
    <main class="min-h-screen">
      <slot />
    </main>
  </body>
</html>