---
// src/layouts/Layout.astro
import { ClientRouter } from 'astro:transitions';
import { siteInfo } from '../data/info';

// 1. IMPORTACIÓN DEL CSS GLOBAL (Fundamental para Tailwind)
import '../styles/global.css';

// 2. IMPORTACIÓN DE COMPONENTES GLOBALES
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
<meta charset="UTF-8" />
    <meta name="description" content={siteInfo.description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | {siteInfo.name}</title>
    
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />

    <ClientRouter />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased selection:bg-brand-primary selection:text-white">
    
    <Navbar />
	<Chatbot />
    <main class="min-h-screen">
      <slot />
    </main>

    <Footer />

  </body>
</html>