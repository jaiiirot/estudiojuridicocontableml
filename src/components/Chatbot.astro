---
// src/components/Chatbot.astro
---

<div id="chatbot-container" transition:persist="chatbot" class="fixed bottom-6 right-6 z-[100] flex flex-col items-end font-sans">
  
  <div id="chat-window" class="hidden w-[90vw] max-w-sm md:w-[400px] h-[75vh] max-h-[450px] md:h-auto bg-web-background rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.5)] mb-4 overflow-hidden flex flex-col transition-all duration-300 transform origin-bottom-right">
    
    <div class="bg-web-secondary text-white px-5 py-3 flex justify-between items-center shadow-md z-10 border-b border-web-primary/20">
      <div class="flex items-center gap-3">
        <div class="relative flex-shrink-0">
          <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center p-1.5 shadow-inner">
            <img src="/logo.png" alt="M&L Logo" class="w-full h-auto object-contain" />
          </div>
          <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-web-secondary rounded-full"></span>
        </div>
        <div>
          <span class="block font-serif font-bold text-base leading-none mb-1">Dirección M&L</span>
          <span class="block text-[8px] text-web-text/70 font-bold tracking-[0.15em] uppercase leading-none">La firma líder en línea</span>
        </div>
      </div>
      
      <div class="flex items-center gap-1">
        <button id="clear-chat" class="text-web-text/60 hover:text-white transition-colors focus:outline-none p-2 rounded-full hover:bg-white/10 cursor-pointer" title="Reiniciar conversación">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        </button>
        <button id="close-chat" class="text-web-text/60 hover:text-white transition-colors focus:outline-none p-2 rounded-full hover:bg-white/10 cursor-pointer" title="Cerrar ventana">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
    </div>

    <div id="chat-messages" class="flex-1 p-4 md:p-5 overflow-y-auto bg-web-background flex flex-col gap-4 text-sm scroll-smooth pb-8" style="scrollbar-width: thin;">
    </div>

    <div id="typing-indicator" class="hidden px-5 pb-4 bg-web-background -mt-4 absolute bottom-[60px] left-0 w-full z-20">
      <div class="bg-web-secondary px-4 py-3 rounded-2xl rounded-tl-none shadow-sm w-fit flex gap-1.5 items-center">
        <div class="w-1.5 h-1.5 bg-web-primary/50 rounded-full animate-bounce"></div>
        <div class="w-1.5 h-1.5 bg-web-primary/50 rounded-full animate-bounce" style="animation-delay: 0.15s"></div>
        <div class="w-1.5 h-1.5 bg-web-primary/50 rounded-full animate-bounce" style="animation-delay: 0.3s"></div>
      </div>
    </div>

    <form id="chat-form" class="p-3 bg-web-background flex gap-2 relative z-30 shadow-[0_-4px_10px_rgba(0,0,0,0.1)]">
      <input type="text" id="chat-input" placeholder="Escriba su consulta..." class="flex-1 px-4 py-2.5 rounded-xl focus:outline-none focus:ring-1 focus:ring-web-primary transition-all text-sm bg-web-secondary/40 text-white placeholder-web-text/40 font-light disabled:opacity-50 border-none" autocomplete="off" />
      <button type="submit" id="chat-submit" class="bg-web-accent text-white px-4 py-2.5 rounded-xl hover:bg-web-secondary transition-colors font-bold shadow-sm flex items-center justify-center transform active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer" title="Enviar consulta">
        <svg class="w-5 h-5 transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
      </button>
    </form>
    
  </div>

  <button id="toggle-chat" class="w-14 h-14 md:w-16 md:h-16 bg-web-secondary rounded-full shadow-2xl flex items-center justify-center hover:bg-web-accent transition-all duration-300 hover:scale-110 focus:outline-none group relative cursor-pointer">
    <div class="absolute inset-0 bg-web-primary rounded-full animate-ping opacity-20"></div>
    <svg class="w-7 h-7 md:w-8 md:h-8 text-white relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
  </button>

</div>

<script>
  import { faqs, chatFlow, WA_NUMBER, fallbackMessage } from '../data/chatbot';
  import DOMPurify from 'dompurify';

  let isChatInitialized = false;
  let isChatOpen = false;

  document.addEventListener('astro:page-load', () => {
    
    if (isChatInitialized) return;

    const toggleBtn = document.getElementById('toggle-chat');
    const closeBtn = document.getElementById('close-chat');
    const clearBtn = document.getElementById('clear-chat');
    const chatWindow = document.getElementById('chat-window');
    const chatForm = document.getElementById('chat-form');
    const chatInput = document.getElementById('chat-input') as HTMLInputElement;
    const chatSubmit = document.getElementById('chat-submit') as HTMLButtonElement;
    const messagesContainer = document.getElementById('chat-messages');
    const typingIndicator = document.getElementById('typing-indicator');

    if(!toggleBtn || !chatWindow || !chatForm || !messagesContainer) return;

    const updateTime = () => new Date().toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' });
    
    const scrollToBottom = () => { 
      setTimeout(() => { messagesContainer.scrollTop = messagesContainer.scrollHeight; }, 50);
    };

    const setLoadingState = (isLoading: boolean) => {
      chatInput.disabled = isLoading;
      chatSubmit.disabled = isLoading;
      if (isLoading) {
        typingIndicator?.classList.remove('hidden');
      } else {
        typingIndicator?.classList.add('hidden');
        chatInput.focus();
      }
      scrollToBottom();
    };

    const disablePreviousOptions = () => {
      const oldOptions = document.querySelectorAll('.chat-options-container');
      oldOptions.forEach(container => container.remove());
    };

    const renderBotMessage = (htmlContent: string) => {
      const msgDiv = document.createElement('div');
      msgDiv.className = 'self-start bg-web-secondary p-4 rounded-2xl rounded-tl-none shadow-sm max-w-[90%] animate-fade-in-up text-web-text';
      
      const rawHTML = htmlContent + `
        <div class="mt-3 text-[9px] text-web-text/50 border-t border-web-primary/20 pt-2 flex justify-between items-center uppercase tracking-widest font-bold">
          <span class="text-web-primary">Firma M&L</span>
          <span>${updateTime()}</span>
        </div>
      `;
      msgDiv.innerHTML = DOMPurify.sanitize(rawHTML);
      
      messagesContainer.appendChild(msgDiv);
      scrollToBottom();
    };

    const renderUserMessage = (text: string) => {
      const msgDiv = document.createElement('div');
      msgDiv.className = 'self-end bg-web-accent text-white px-4 py-3 rounded-2xl rounded-tr-none shadow-sm max-w-[85%] mt-1 mb-2 animate-fade-in-up';
      
      const rawHTML = `
        <p class="text-sm font-light leading-relaxed">${text}</p>
        <span class="block text-[9px] text-white/70 text-right mt-1 font-bold">${updateTime()}</span>
      `;
      msgDiv.innerHTML = DOMPurify.sanitize(rawHTML);

      messagesContainer.appendChild(msgDiv);
      scrollToBottom();
    };

    const generateWaButton = (text: string, waQuery: string) => {
      const waLink = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(waQuery)}`;
      return `
        <a href="${waLink}" target="_blank" class="mt-4 flex items-center justify-center gap-2 bg-[#25D366] text-white px-4 py-2.5 rounded-xl font-bold text-[10px] md:text-[11px] uppercase tracking-wider hover:bg-[#1ebe5b] transition-all duration-300 shadow-md cursor-pointer">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
          ${text}
        </a>
      `;
    };

    const renderNode = (nodeId: string) => {
      const node = chatFlow[nodeId];
      if (!node) return;
      disablePreviousOptions();
      setLoadingState(true);

      const delay = Math.min(Math.max(node.message.length * 15, 800), 2000);
      setTimeout(() => {
        setLoadingState(false);

        let html = `<p class="text-sm font-light leading-relaxed">${node.message}</p>`;

        if (node.isEnd) {
          const waQuery = "Hola, utilicé el asistente guiado en su web. Requiero contactarme con sus especialistas para que analicen mi caso.";
          html += generateWaButton("Derivar caso a los expertos", waQuery);
        }

        renderBotMessage(html);

        if (node.options && node.options.length > 0) {
          const optionsDiv = document.createElement('div');
          optionsDiv.className = 'chat-options-container flex flex-col gap-2 mt-2 w-full animate-fade-in-up';
          
          node.options.forEach(opt => {
            const btn = document.createElement('button');
            // Añadido cursor-pointer aquí
            btn.className = 'text-left w-full bg-web-secondary/80 text-web-text px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-web-accent hover:text-white transition-all duration-300 shadow-sm cursor-pointer';
            btn.textContent = opt.label;
            btn.addEventListener('click', () => {
              renderUserMessage(opt.label);
              renderNode(opt.next);
            });
            optionsDiv.appendChild(btn);
          });
          
          messagesContainer.appendChild(optionsDiv);
          scrollToBottom();
        }
      }, delay);
    };

    const normalizeText = (text: string) => text.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

    chatForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const userTextRaw = chatInput.value.trim();
      if (!userTextRaw) return;

      disablePreviousOptions();
      renderUserMessage(userTextRaw);
      chatInput.value = '';
      
      setLoadingState(true);

      setTimeout(() => {
        setLoadingState(false);
        const normalizedInput = normalizeText(userTextRaw);
       
        const foundFaq = faqs.find(faq => faq.keywords.some(kw => normalizedInput.includes(normalizeText(kw))));
        
        let responseText = foundFaq ? foundFaq.answer : fallbackMessage;
        
        const waQuery = `Hola, esta es mi consulta desde la web: "${userTextRaw}". Deseo que la firma M&L asuma mi caso.`;
        const html = `
          <p class="text-sm font-light leading-relaxed">${responseText}</p>
          ${generateWaButton("Hablar con un Profesional", waQuery)}
        `;

        renderBotMessage(html);
      }, 1000); 
    });

    const initChat = () => {
      messagesContainer.innerHTML = '';
      renderNode('inicio');
    };

    toggleBtn.addEventListener('click', () => {
      isChatOpen = !isChatOpen;
      chatWindow.classList.toggle('hidden');
      if (isChatOpen && messagesContainer.innerHTML.trim() === '') {
        initChat();
      }
    });

    closeBtn?.addEventListener('click', () => {
      isChatOpen = false;
      chatWindow.classList.add('hidden');
    });

    clearBtn?.addEventListener('click', () => {
      chatInput.value = '';
      initChat();
    });

    isChatInitialized = true;
  });
</script>

<style is:global>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translate3d(0, 10px, 0); }
    to { opacity: 1; transform: translate3d(0, 0, 0); }
  }
  .animate-fade-in-up { animation: fadeInUp 0.3s ease-out forwards; }
</style>