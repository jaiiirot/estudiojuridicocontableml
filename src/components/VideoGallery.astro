---
// src/components/VideoGallery.astro
import { videoReels } from '../data/videos';
import { siteInfo } from '../data/info';
---
<section class="py-24 bg-gray-900 text-white">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
      {videoReels.map((video) => (
        <a href={`https://instagram.com/${siteInfo.social.instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="group block h-full">
          <div class="bg-gray-800 rounded-xl overflow-hidden h-full border border-gray-700 hover:border-brand-primary transition-colors flex flex-col relative">
            
            <div class="h-48 bg-gray-900 relative flex items-center justify-center overflow-hidden">
              <img src={video.thumbnail} alt={video.title} class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-40 transition-opacity" loading="lazy" />
              
              <div class="w-12 h-12 rounded-full border-2 border-white flex items-center justify-center z-20 group-hover:scale-110 group-hover:bg-brand-primary group-hover:border-brand-primary transition-all">
                <svg class="w-5 h-5 text-white ml-1" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4l12 6-12 6z"></path></svg>
              </div>
            </div>

            <div class="p-6 flex flex-col flex-grow">
              <span class="text-brand-primary text-xs font-bold uppercase tracking-wide mb-2 block">{video.category}</span>
              <h3 class="text-lg font-bold font-serif mb-3 group-hover:text-white transition-colors line-clamp-2">
                {video.title}
              </h3>
              <p class="text-sm text-gray-400 font-light leading-relaxed flex-grow">
                {video.description}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>