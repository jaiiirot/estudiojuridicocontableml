---
// src/components/home/Hero.astro
import { siteInfo } from '../../data/info';
import { tiktokVideos } from '../../data/videos'; // Importamos tus videos

// Elegimos el primer video de tu lista para mostrarlo en el Hero
const featuredVideo = tiktokVideos[0];
---

<section class="relative bg-white min-h-[85vh] flex items-center pt-10 pb-20 lg:pt-10 lg:pb-32 overflow-hidden">
  <div class="absolute top-0 right-0 w-full md:w-1/2 h-full bg-brand-light/40 skew-x-[-10deg] translate-x-20 -z-10 hidden md:block"></div>
  <div class="absolute -top-24 -left-24 w-96 h-96 bg-brand-light rounded-full mix-blend-multiply filter blur-[80px] opacity-70 -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-12">
      
      <div class="w-full lg:w-1/2 space-y-8">
        
        <div class="flex items-center gap-4">
          <div class="w-12 h-[2px] bg-brand-primary"></div>
          <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.25em] text-brand-dark">Estudio Jurídico & Contable</span>
        </div>
        
        <h1 class="text-5xl sm:text-6xl lg:text-[5rem] font-serif font-bold text-brand-dark leading-[1.05] tracking-tight">
          Protegemos su <br />
          <span class="relative inline-block mt-2">
            <span class="relative z-10 text-brand-primary italic font-light pr-2">patrimonio.</span>
            <svg class="absolute w-full h-3 -bottom-2 left-0 text-brand-primary/20 -z-10" viewBox="0 0 100 10" preserveAspectRatio="none">
              <path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="4" fill="none" />
            </svg>
          </span>
        </h1>
        
        <div class="border-l-2 border-brand-primary/30 pl-6 py-2">
          <p class="text-lg md:text-xl text-gray-600 font-light leading-relaxed max-w-lg">
            Estrategia legal implacable y optimización fiscal de precisión en <strong class="font-medium text-brand-dark">Avellaneda</strong>. Asumimos sus conflictos para que usted recupere su tranquilidad.
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-5 pt-4">
          <a 
            href={`https://wa.me/${siteInfo.contact.whatsapp}?text=Hola,%20requiero%20una%20auditoría%20legal/contable.`} 
            target="_blank" 
            class="group relative inline-flex items-center justify-center bg-brand-dark text-white px-8 py-4 font-bold uppercase tracking-widest text-xs transition-all duration-300 hover:bg-brand-primary hover:shadow-xl hover:shadow-brand-primary/20"
          >
            <span class="relative z-10 flex items-center gap-3">
              Agendar Auditoría
              <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </span>
          </a>
          
          <a 
            href="#servicios" 
            class="group inline-flex items-center justify-center px-8 py-4 font-bold uppercase tracking-widest text-xs text-brand-dark border border-gray-200 transition-all duration-300 hover:border-brand-primary hover:text-brand-primary bg-white hover:bg-brand-light/50"
          >
            Ver Servicios
          </a>
        </div>
      </div>

      <div class="w-full lg:w-1/2 relative lg:pl-10 mt-10 lg:mt-0">
        <div class="absolute inset-0 bg-brand-dark/5 translate-x-6 translate-y-6 md:translate-x-10 md:translate-y-10 z-0 border border-brand-primary/10"></div>
        
        <div class="relative z-10 aspect-[3/4] sm:aspect-[4/5] w-full max-w-md mx-auto lg:max-w-none overflow-hidden bg-gray-900 shadow-2xl group">
          <tiktok-video 
            class="w-full h-full relative cursor-pointer bg-cover bg-center hover:bg-[length:105%] transition-[background-size] duration-700 block" 
            videoid={featuredVideo.id} 
            title={featuredVideo.title} 
            role="button" 
            tabindex="0" 
            style={`background-image: url('${featuredVideo.thumbnail}');`}
          >
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent group-hover:bg-black/50 transition-colors duration-500"></div>
            
            <div class="absolute inset-0 flex items-center justify-center z-10">
              <div class="w-20 h-20 bg-brand-primary text-white rounded-full flex items-center justify-center shadow-[0_0_40px_rgba(0,0,0,0.5)] transform transition-all duration-300 group-hover:scale-110 group-hover:bg-brand-dark pl-2">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>

            <div class="absolute bottom-10 left-8 right-8 z-10">
              <span class="inline-block bg-brand-primary text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 mb-3 shadow-md">
                Video Destacado
              </span>
              <h3 class="text-white font-serif font-bold text-2xl md:text-3xl leading-tight line-clamp-3 drop-shadow-lg">
                {featuredVideo.title}
              </h3>
            </div>
          </tiktok-video>
        </div>
        
        <div class="absolute -bottom-6 -left-4 md:-bottom-10 md:-left-8 bg-white p-5 md:p-7 shadow-2xl z-20 border-l-4 border-brand-primary flex items-center gap-5 transform transition-transform duration-500 hover:-translate-y-2 pointer-events-none">
          <div class="hidden sm:flex bg-brand-light p-3 md:p-4 rounded-full items-center justify-center text-brand-primary">
            <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
            </svg>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-serif font-bold text-brand-dark">+10</p>
            <p class="text-[9px] md:text-[11px] font-bold uppercase tracking-[0.2em] text-gray-500 mt-1 leading-tight">Años de <br/>Trayectoria</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Script embebido para asegurar que el componente funcione en el Hero
  document.addEventListener('astro:page-load', () => {
    class TikTokVideo extends HTMLElement {
      connectedCallback() {
        this.addEventListener('click', () => {
          const videoId = this.getAttribute('videoid');
          this.style.backgroundImage = 'unset';
          this.innerHTML = `
            <div class="w-full h-full flex items-center justify-center bg-black">
              <div class="w-8 h-8 border-4 border-brand-primary border-t-transparent rounded-full animate-spin absolute"></div>
              <iframe 
                width="100%" 
                height="100%" 
                class="relative z-10 w-full h-full object-cover" 
                title="TikTok Video" 
                allow="autoplay; fullscreen" 
                src="https://www.tiktok.com/player/v1/${videoId}?autoplay=1">
              </iframe>
            </div>
          `;
        }, { once: true });
      }
    }
    
    // Lo registramos solo si no ha sido registrado por la galería
    if (!customElements.get('tiktok-video')) {
      customElements.define('tiktok-video', TikTokVideo);
    }
  });
</script>