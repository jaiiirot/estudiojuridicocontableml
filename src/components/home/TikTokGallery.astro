---
// src/components/home/TikTokGallery.astro
import Icon from '../ui/Icon.astro';
import { tiktokVideos } from '../../data/videos.ts';
---

<section class="py-24 bg-brand-dark overflow-hidden">
  <div class="mx-auto max-w-7xl w-full px-4 sm:px-6 lg:px-8">
    
    <div class="flex items-center justify-between pb-8 md:pb-12">
      <div>
        <span class="text-brand-primary font-bold tracking-widest uppercase text-sm mb-2 block">Capacitación Legal</span>
        <h2 class="font-serif font-bold text-3xl md:text-5xl text-white">
          Novedades en Video
        </h2>
      </div>
      
      <div class="hidden md:flex items-center gap-x-4">
        <button id="left-button" class="bg-gray-800 text-gray-400 p-3 rounded-full hover:bg-brand-primary hover:text-white transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed" aria-label="Anterior">
          <Icon name="leftarrow" class="w-6 h-6" />
        </button>
        <button id="right-button" class="bg-gray-800 text-gray-400 p-3 rounded-full hover:bg-brand-primary hover:text-white transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed" aria-label="Siguiente">
          <Icon name="rightarrow" class="w-6 h-6" />
        </button>
      </div>
    </div>

    <div class="relative carousel-container -mx-4 px-4 md:mx-0 md:px-0">
      <div id="tiktok-carousel" class="flex overflow-x-auto scrollbar-hide gap-x-4 md:gap-x-6 snap-mandatory snap-x pb-8">
        
        {tiktokVideos.map((video) => (
          <tiktok-video 
            class="rounded-2xl h-[500px] md:h-[570px] w-72 md:w-80 snap-center bg-gray-900 relative shrink-0 cursor-pointer bg-cover bg-center hover:bg-[length:105%] transition-[background-size] duration-500 shadow-xl border border-gray-800 group" 
            videoid={video.id} 
            title={video.title} 
            role="button" 
            tabindex="0" 
            style={`background-image: url('${video.thumbnail}');`}
          >
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent rounded-2xl group-hover:bg-black/40 transition-colors"></div>
            
            <span class="absolute top-4 left-4 bg-brand-primary text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-sm z-10">
              {video.category}
            </span>

            <div class="absolute bottom-24 left-6 right-6 z-10">
              <h3 class="text-white font-serif font-bold text-xl leading-tight line-clamp-3">{video.title}</h3>
            </div>

            <div class="p-4 pl-5 bg-white text-brand-dark rounded-full absolute bottom-6 right-6 group-hover:scale-110 group-hover:bg-brand-primary group-hover:text-white transition-all duration-300 shadow-lg z-10 flex items-center justify-center">
              <Icon name="play" class="w-4 h-4" />
            </div>
          </tiktok-video>
        ))}

      </div>
    </div>
    
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    
    // 1. Lógica del Custom Element <tiktok-video>
    class TikTokVideo extends HTMLElement {
      connectedCallback() {
        this.addEventListener('click', () => {
          const videoId = this.getAttribute('videoid');
          // Limpiamos el fondo y el contenido HTML (botón play, etc.)
          this.style.backgroundImage = 'unset';
          this.innerHTML = `
            <div class="w-full h-full flex items-center justify-center bg-black rounded-2xl">
              <div class="w-8 h-8 border-4 border-brand-primary border-t-transparent rounded-full animate-spin absolute"></div>
              <iframe 
                width="100%" 
                height="100%" 
                class="rounded-2xl relative z-10" 
                title="TikTok Video" 
                allow="autoplay; fullscreen" 
                src="https://www.tiktok.com/player/v1/${videoId}?autoplay=1">
              </iframe>
            </div>
          `;
        }, { once: true }); // Solo ejecuta el click una vez
      }
    }
    
    // Registramos el elemento si no existe
    if (!customElements.get('tiktok-video')) {
      customElements.define('tiktok-video', TikTokVideo);
    }

    // 2. Lógica de las Flechas del Carrusel
    const carousel = document.getElementById('tiktok-carousel');
    const leftBtn = document.getElementById('left-button');
    const rightBtn = document.getElementById('right-button');

    if (carousel && leftBtn && rightBtn) {
      // Función para calcular la distancia de scroll (1 elemento + gap)
      const scrollAmount = () => carousel.firstElementChild ? carousel.firstElementChild.clientWidth + 24 : 300;

      leftBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
      });

      rightBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
      });
    }
  });
</script>