---
// src/components/home/PracticeAreas.astro
import { services } from '../../data/services';
---

<section class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-16">
      <div class="max-w-2xl">
        <h2 class="text-4xl font-serif font-bold text-gray-900 mb-6">Nuestras Áreas de Práctica</h2>
        <div class="w-24 h-1.5 bg-brand-primary"></div>
      </div>
      <p class="text-gray-600 font-light max-w-md mt-6 md:mt-0">
        Abordaje interdisciplinario para garantizar soluciones integrales tanto en el ámbito personal como corporativo.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {services.map((service, index) => (
        <a href={`/especialidades/${service.id}`} class="group block bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-2xl transition-all duration-300 hover:border-brand-primary">
          <div class="p-10 relative">
            <span class="absolute top-10 right-10 text-5xl font-serif font-bold text-gray-100 group-hover:text-brand-light transition-colors">
              0{index + 1}
            </span>
            <div class="relative z-10">
              <h3 class="text-2xl font-serif font-bold text-gray-900 mb-4 group-hover:text-brand-primary transition-colors">{service.title}</h3>
              <p class="text-gray-600 mb-8 font-light leading-relaxed">
                {service.shortDesc}
              </p>
              <div class="flex items-center text-brand-dark font-bold text-sm uppercase tracking-widest group-hover:text-brand-primary transition-colors">
                <span>Conocer más</span>
                <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>