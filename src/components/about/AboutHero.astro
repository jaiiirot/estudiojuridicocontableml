---
// src/components/about/AboutHero.astro
---

<section class="bg-white pt-32 pb-24 border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-4xl mx-auto">
      <span class="text-brand-primary font-bold uppercase tracking-[0.2em] text-xs border-b border-brand-primary pb-1">
        Identidad Corporativa
      </span>
      
      <h1 class="text-4xl md:text-6xl font-serif font-bold text-brand-dark mt-8 mb-8 leading-tight">
        Respaldo integral para <br/>
        <span class="text-gray-900">particulares y empresas.</span>
      </h1>
      
      <p class="text-lg md:text-xl text-gray-600 font-light leading-relaxed max-w-2xl mx-auto">
        Somos un estudio jurídico y contable radicado en Avellaneda, a 10 minutos de C.A.B.A. Nacimos con la convicción de brindar orden, transparencia y soluciones definitivas a los problemas de nuestros clientes.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-20">
      <div class="h-64 rounded-xl overflow-hidden shadow-sm">
        <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&q=80&w=600" alt="Oficinas" class="w-full h-full object-cover" />
      </div>
      <div class="h-64 rounded-xl overflow-hidden shadow-sm md:-translate-y-8">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=600" alt="Sala de reuniones" class="w-full h-full object-cover" />
      </div>
      <div class="h-64 rounded-xl overflow-hidden shadow-sm">
        <img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&q=80&w=600" alt="Firma de documentos" class="w-full h-full object-cover" />
      </div>
    </div>

  </div>
</section>