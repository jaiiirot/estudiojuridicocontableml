---
// src/components/about/Team.astro

const team = [
  {
    name: "Dr. [Nombre M.]",
    role: "Socio Director - Área Legal",
    description: "Especialista en litigios complejos, Derecho Laboral y Familia. Lidera la estrategia jurídica de la firma con más de 10 años de experiencia en tribunales.",
    image: "https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80&w=800",
    linkedin: "#"
  },
  {
    name: "Cont. [Nombre L.]",
    role: "Socia Directora - Área Contable",
    description: "Experta en planificación fiscal, auditoría y asesoramiento corporativo para PyMEs. Optimiza el patrimonio de nuestros clientes corporativos.",
    image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=800",
    linkedin: "#"
  },
  {
    name: "Dr. [Nombre Asociado]",
    role: "Abogado Asociado",
    description: "Dedicado a la gestión ágil de expedientes previsionales (jubilaciones) y sucesiones, garantizando un seguimiento meticuloso de cada caso.",
    image: "https://images.unsplash.com/photo-1556157382-97eda2d62296?auto=format&fit=crop&q=80&w=800",
    linkedin: "#"
  }
];
---

<section class="py-20 lg:py-32 bg-white relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-brand-primary/20 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-24">
      <div class="flex items-center justify-center gap-4 mb-4">
        <div class="w-8 h-[2px] bg-brand-primary"></div>
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-dark">La Firma</span>
        <div class="w-8 h-[2px] bg-brand-primary"></div>
      </div>
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-brand-dark tracking-tight mb-6">
        Nuestro Equipo de <span class="text-brand-primary italic font-light">Especialistas</span>
      </h2>
      <p class="text-lg text-gray-600 font-light leading-relaxed">
        Un equipo interdisciplinario de abogados y contadores comprometidos con la excelencia, la ética profesional y la defensa inclaudicable de sus intereses.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-14">
      {team.map((member) => (
        <div class="group flex flex-col">
          <div class="relative w-full aspect-[3/4] bg-gray-100 overflow-hidden mb-6">
            <div class="absolute inset-0 bg-brand-dark/20 mix-blend-multiply z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <img 
              src={member.image} 
              alt={member.name} 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="absolute bottom-4 right-4 z-20 bg-white text-brand-dark p-3 shadow-lg opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 hover:bg-brand-primary hover:text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
          </div>
          
          <div>
            <h3 class="text-2xl font-serif font-bold text-brand-dark mb-1">{member.name}</h3>
            <p class="text-brand-primary text-xs font-bold uppercase tracking-widest mb-4">{member.role}</p>
            <p class="text-gray-600 font-light leading-relaxed text-sm">
              {member.description}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>