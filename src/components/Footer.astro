---
// src/components/Footer.astro
import Icon from './ui/Icon.astro';
import { siteInfo } from '../data/info';

const depJuridico = [
  { name: 'Derecho Civil y Comercial', url: '/especialidades/derecho-civil-y-comercial' },
  { name: 'Derecho de Familia', url: '/especialidades/derecho-de-familia' },
  { name: 'Derecho Laboral', url: '/especialidades/derecho-laboral' },
  { name: 'Derecho Previsional', url: '/especialidades/derecho-previsional' }
];

const depContable = [
  { name: 'Servicios Contables e Impositivos', url: '/especialidades/departamento-contable' },
  { name: 'Abonos para PyMES', url: '/abonos' }
];
---

<footer class="bg-brand-dark pt-20 pb-10 border-t-4 border-brand-primary font-sans relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-1 bg-brand-primary blur-[100px] opacity-40"></div>

  <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-16">
      
      <div class="lg:col-span-4 lg:pr-8">
        <a href="/" class="inline-block mb-6 group">
          <div class="flex items-center gap-3">
            <img src="/logo.png" alt="Logo Estudio M&L" class="h-16 w-auto group-hover:scale-105 transition-transform duration-500 brightness-0 invert" />
            <div class="flex flex-col justify-center">
              <span class="text-2xl font-serif font-bold text-white tracking-tight leading-none mb-1">M&L</span>
              <span class="text-[0.65rem] font-sans font-bold text-brand-primary uppercase tracking-[0.2em] leading-none">Estudio Jurídico</span>
            </div>
          </div>
        </a>
        <p class="text-gray-400 font-light leading-relaxed text-sm mb-8 pr-4">
          Firma líder en Avellaneda. Brindamos blindaje patrimonial, estrategias legales implacables y optimización fiscal para empresas y particulares exigentes.
        </p>
        <a href="/consulta" class="inline-flex items-center gap-2 text-brand-primary text-xs font-bold uppercase tracking-widest hover:text-white transition-colors group">
          Iniciar Análisis Preliminar
          <Icon name="rightarrow" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" />
        </a>
      </div>

      <div class="lg:col-span-3">
        <span class="text-white font-serif font-bold text-lg mb-6 block">Dep. Jurídico</span>
        <ul class="space-y-4">
          {depJuridico.map((item) => (
            <li>
              <a href={item.url} class="text-gray-400 hover:text-brand-primary transition-colors text-sm font-light flex items-center gap-2 group">
                <span class="w-1 h-1 bg-brand-primary rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-2">
        <span class="text-white font-serif font-bold text-lg mb-6 block">Dep. Contable</span>
        <ul class="space-y-4">
          {depContable.map((item) => (
            <li>
              <a href={item.url} class="text-gray-400 hover:text-brand-primary transition-colors text-sm font-light flex items-center gap-2 group">
                <span class="w-1 h-1 bg-brand-primary rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-3">
        <span class="text-white font-serif font-bold text-lg mb-6 block">Nuestra Sede</span>
        <ul class="space-y-4 text-sm font-light text-gray-400">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span>Av. Pres. Bartolomé Mitre 2443,<br/>Avellaneda, Buenos Aires</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <span>{siteInfo.contact.whatsappDisplay}</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>Lunes a Viernes<br/>12:00 a 18:00 hs</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="h-px w-full bg-gray-800 mb-8"></div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      
      <div class="text-gray-500 text-xs font-light text-center md:text-left">
        &copy; {new Date().getFullYear()} Estudio Jurídico Contable M&L. Todos los derechos reservados.<br class="md:hidden" />
        <span class="hidden md:inline"> | </span>
        <a href="/terminos" class="hover:text-white transition-colors">Términos de Servicio</a>
        <span class="mx-2">&middot;</span>
        <a href="/privacidad" class="hover:text-white transition-colors">Política de Privacidad</a>
      </div>

     <div class="flex items-center space-x-5">
        <a href={siteInfo.social.instagram} target="_blank" aria-label="Instagram" class="text-gray-500 hover:text-brand-primary transition-transform hover:-translate-y-1 bg-white/5 p-2 rounded-full hover:bg-white/10">
          <Icon name="instagram" class="w-4 h-4" />
        </a>
        <a href={siteInfo.social.tiktok} target="_blank" aria-label="TikTok" class="text-gray-500 hover:text-white transition-transform hover:-translate-y-1 bg-white/5 p-2 rounded-full hover:bg-white/10">
          <Icon name="tiktok" class="w-4 h-4" />
        </a>
        <a href={siteInfo.social.linkedin} target="_blank" aria-label="LinkedIn" class="text-gray-500 hover:text-[#0a66c2] transition-transform hover:-translate-y-1 bg-white/5 p-2 rounded-full hover:bg-white/10">
          <Icon name="linkedin" class="w-4 h-4" />
        </a>
      </div>

    </div>

  </div>
</footer>