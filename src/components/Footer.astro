---
// src/components/Footer.astro
import { siteInfo } from '../data/info';
import Icon from './ui/Icon.astro';
---

<footer class="bg-[#1a0508] text-white pt-20 pb-10 border-trelative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 mb-16">
      
      <div class="md:col-span-4 space-y-6">
        <a href="/" class="flex items-center gap-4 inline-block">
          <div class="bg-white p-2 rounded-xl">
            <img src="/logo.png" alt="Logo M&L" class="h-16 w-auto" />
          </div>
          <div>
            <h3 class="text-2xl font-serif font-bold tracking-tight leading-none mb-1 text-white">M&L</h3>
            <span class="text-[0.65rem] font-sans font-bold text-gray-400 uppercase tracking-[0.2em] leading-none block">Estudio Jurídico</span>
          </div>
        </a>
        <p class="text-gray-400 font-light leading-relaxed text-sm pr-4">
          {siteInfo.differential}
        </p>
        <div class="flex space-x-4 pt-2">
          <a href={`https://instagram.com/${siteInfo.social.instagram.replace('@', '')}`} target="_blank" aria-label="Instagram" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-brand-primary hover:text-white transition-all">
            <Icon name="instagram" class="w-5 h-5" />
          </a>
          <a href={`https://wa.me/${siteInfo.contact.whatsapp}`} target="_blank" aria-label="WhatsApp" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-[#25D366] hover:text-white transition-all">
            <Icon name="whatsapp" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <div class="md:col-span-3 lg:col-span-4 md:pl-8">
        <h4 class="text-sm font-bold text-brand-primary tracking-widest uppercase mb-6">Navegación</h4>
        <ul class="space-y-4">
          <li><a href="/nosotros" class="text-gray-400 hover:text-white transition-colors text-sm">Nuestra Firma</a></li>
          <li><a href="/especialidades/derecho-civil-y-comercial" class="text-gray-400 hover:text-white transition-colors text-sm">Áreas de Práctica</a></li>
          <li><a href="/abonos" class="text-gray-400 hover:text-white transition-colors text-sm">Planes y Abonos</a></li>
          <li><a href="/consulta" class="text-gray-400 hover:text-brand-primary transition-colors text-sm flex items-center gap-2">Asistente IA <span class="bg-brand-primary/20 text-brand-primary text-[10px] px-2 py-0.5 rounded uppercase font-bold">Nuevo</span></a></li>
        </ul>
      </div>

      <div class="md:col-span-5 lg:col-span-4">
        <h4 class="text-sm font-bold text-brand-primary tracking-widest uppercase mb-6">Oficinas y Contacto</h4>
        <ul class="space-y-4 text-gray-400 font-light text-sm">
          <li class="flex items-start">
            <span class="leading-relaxed">Av. Pres. Bartolomé Mitre 2443,<br/> Avellaneda, Buenos Aires.</span>
          </li>
          <li class="flex items-center">
            <span>Lunes a Viernes de 12:00 a 18:00hs.</span>
          </li>
          <li class="flex items-center pt-2">
            <a href={`https://wa.me/${siteInfo.contact.whatsapp}`} target="_blank" class="text-white hover:text-brand-primary font-bold text-lg transition-colors border-b border-gray-700 hover:border-brand-primary pb-1">
              +54 9 11 2789-0450
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-xs font-light">
        &copy; {new Date().getFullYear()} Estudio Jurídico Contable M&L. Todos los derechos reservados.
      </p>
      <p class="text-gray-600 text-xs font-light">
        Desarrollado con <span class="text-brand-primary">❤</span>
      </p>
    </div>
  </div>
</footer>