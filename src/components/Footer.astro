---
// src/components/Footer.astro
import { siteInfo } from '../data/info';
---

<footer class="bg-brand-dark text-white pt-16 pb-8 border-t-4 border-brand-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <div class="space-y-4">
        <h3 class="text-2xl font-serif font-bold tracking-wide">{siteInfo.name}</h3>
        <p class="text-gray-300 font-light leading-relaxed">
          {siteInfo.differential}
        </p>
      </div>

      <div class="space-y-4">
        <h4 class="text-lg font-bold text-brand-primary tracking-widest uppercase text-sm">Contacto</h4>
        <ul class="space-y-3 text-gray-300 font-light">
          <li class="flex items-start">
            <span class="mt-1 mr-3 text-brand-primary">📍</span>
            <span>Av. Pres. Bartolomé Mitre 2443, Avellaneda, Bs. As. [cite: 126]</span>
          </li>
          <li class="flex items-center">
            <span class="mr-3 text-brand-primary">📞</span>
            <span>Teléfono: 77108303 [cite: 116]</span>
          </li>
          <li class="flex items-center">
            <span class="mr-3 text-brand-primary">📱</span>
            <span>WhatsApp: 1132989665 [cite: 117]</span>
          </li>
          <li class="flex items-center">
            <span class="mr-3 text-brand-primary">✉️</span>
            <span>info@estudiojuridicocontableml.com [cite: 126]</span>
          </li>
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="text-lg font-bold text-brand-primary tracking-widest uppercase text-sm">Atención</h4>
        <div class="text-gray-300 font-light space-y-3">
          <p class="flex items-center">
            <span class="mr-3 text-brand-primary">🕒</span>
            Lunes a Viernes de 13 a 18hs. [cite: 125]
          </p>
          <div class="pt-4 mt-4 border-t border-brand-secondary">
            <a href={`https://instagram.com/${siteInfo.social.instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="hover:text-brand-primary transition-colors flex items-center">
              <span class="mr-2">📸</span> Instagram: @estudiojuridicocontableml [cite: 124]
            </a>
          </div>
        </div>
      </div>

    </div>

    <div class="text-center text-sm font-light text-gray-400 pt-8 border-t border-brand-secondary">
      &copy; {new Date().getFullYear()} {siteInfo.name}. Todos los derechos reservados.
    </div>
  </div>
</footer>