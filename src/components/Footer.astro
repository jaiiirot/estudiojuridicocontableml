---
// src/components/Footer.astro
import { siteInfo } from '../data/info';
---

<footer class="bg-brand-dark text-white pt-16 pb-8 border-t border-brand-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <div class="space-y-4">
        <div class="flex items-center gap-4 border-b border-gray-700 pb-4 mb-4">
          <div class="bg-white/10 p-2 rounded-lg">
            <img src="/logo.png" alt="Logo M&L" class="h-14 w-auto brightness-200" />
          </div>
          <div>
            <h3 class="text-2xl font-serif font-bold tracking-wide">{siteInfo.name}</h3>
            <span class="text-brand-light text-xs uppercase tracking-widest block mt-1">Abogados & Contadores</span>
          </div>
        </div>
        
        <p class="text-gray-300 font-light leading-relaxed">
          {siteInfo.differential}
        </p>
      </div>

      <div class="space-y-4">
        <h4 class="text-lg font-bold text-brand-light tracking-widest uppercase text-sm border-b border-gray-700 pb-2">Contacto</h4>
        <ul class="space-y-3 text-gray-300 font-light">
          <li class="flex items-start">
            <span class="mt-1 mr-3 text-gray-400">Dirección:</span>
            <span>Av. Pres. Bartolomé Mitre 2443, Avellaneda, Bs. As.</span>
          </li>
          <li class="flex items-center">
            <span class="mr-3 text-gray-400">Tel:</span>
            <span>77108303</span>
          </li>
          <li class="flex items-center">
            <span class="mr-3 text-gray-400">WhatsApp:</span>
            <span>1132989665</span>
          </li>
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="text-lg font-bold text-brand-light tracking-widest uppercase text-sm border-b border-gray-700 pb-2">Atención</h4>
        <div class="text-gray-300 font-light space-y-3">
          <p class="flex items-center">
            <span class="mr-3 text-gray-400">Horarios:</span>
            Lunes a Viernes de 13 a 18hs.
          </p>
          <div class="pt-4 mt-4 border-t border-gray-700">
            <a href={`https://instagram.com/${siteInfo.social.instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors flex items-center text-sm">
              <span class="mr-2 text-gray-400">IG:</span> @estudiojuridicocontableml
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</footer>